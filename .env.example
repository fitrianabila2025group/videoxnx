# Public URL of the site (used in canonical tags / sitemap / robots).
APP_URL=http://localhost:8080

# Container listens on this single port (frontend + API).
PORT=8080

# SQLite — no external database required.
DATABASE_URL=sqlite:///data/videoxnx.db

# Strong random string. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# Admin account auto-created on first boot. CHANGE THESE.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# Scraper
SOURCE_BASE_URL=https://indoxvx.cam
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_MINUTES=60
SCRAPER_MAX_PAGES=200
SCRAPER_RATE_LIMIT_MS=1500
SCRAPER_RESPECT_ROBOTS=false
SCRAPER_USER_AGENT=VideoxnxAggregatorBot/1.0
# Optional botasaurus microservice (leave blank to use direct HTTP).
SCRAPER_FETCHER_URL=

# Site metadata
AGE_GATE_ENABLED=true
DMCA_EMAIL=dmca@example.com
SITE_NAME=VideoXNX
META_TITLE=VideoXNX
META_DESCRIPTION=Aggregated video posts mirror

# CORS — for the all-in-one image you can leave "*" since API & frontend
# share the same origin.
CORS_ALLOWED_ORIGINS=*
APP_ENV=development
APP_URL=http://localhost:8080
SITE_URL=http://localhost:3000
PORT=8080

DATABASE_URL=sqlite://data/videoxnx.db
# Or use Postgres if you prefer:
# DATABASE_URL=postgres://videoxnx:videoxnx@postgres:5432/videoxnx?sslmode=disable
REDIS_URL=

JWT_SECRET=change-me-to-a-long-random-string

ADMIN_EMAIL=mpratamagpt@gmail.com
ADMIN_PASSWORD=Anonymous263

SOURCE_BASE_URL=https://indoxvx.cam
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_MINUTES=60
SCRAPER_MAX_PAGES=200
SCRAPER_RATE_LIMIT_MS=1500
SCRAPER_RESPECT_ROBOTS=false
SCRAPER_USER_AGENT=VideoxnxAggregatorBot/1.0 (+contact@example.com)
# When set, the Go scraper proxies all requests through the botasaurus
# Python microservice that can solve Cloudflare challenges. Leave blank
# to use direct HTTP only.
SCRAPER_FETCHER_URL=http://fetcher:9090

AGE_GATE_ENABLED=true
DMCA_EMAIL=dmca@example.com
SITE_NAME=VideoXNX
META_TITLE=VideoXNX - Aggregated video posts
META_DESCRIPTION=Aggregated video posts mirror

CORS_ALLOWED_ORIGINS=http://localhost:3000
